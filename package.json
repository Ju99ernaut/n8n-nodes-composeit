{
    "name": "n8n-nodes-composeit",
    "version": "0.1.1",
    "description": "n8n community node package for ComposeIt Document Generation API integrations",
    "license": "MIT",
    "homepage": "https://composeit.app",
    "keywords": [
        "n8n-community-node-package",
        "documents",
        "emails",
        "automation"
    ],
    "author": {
        "name": "Ju99ernaut",
        "email": "48953676+Ju99ernaut@users.noreply.github.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ju99ernaut/n8n-nodes-composeit.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/ComposeItApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/ComposeIt/ComposeIt.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
